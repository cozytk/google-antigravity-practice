# Cloud Runмқҙ мӢӨн–үн•  м»Ён…Ңмқҙл„Ҳмқҳ м„Өкі„лҸ„.
# gcloud run deploy --source . мӢӨн–ү мӢң Cloud Buildк°Җ мқҙ нҢҢмқјлЎң мқҙлҜём§ҖлҘј л§Ңл“ лӢӨ.
FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Cloud RunмқҖ PORT нҷҳкІҪ ліҖмҲҳлЎң нҸ¬нҠёлҘј м§Җм •н•ңлӢӨ (кё°ліё 8080)
ENV PORT=8080
CMD exec uvicorn main:app --host 0.0.0.0 --port ${PORT}
